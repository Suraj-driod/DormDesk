        "touch_optimizations": {
          "minimum_spacing": "12px between tappable elements",
          "tap_target_size": "Minimum 44x44px",
          "swipe_gestures": "Support for back/forward navigation"
        }
      },
  
      "design_principles": {
        "clarity": "Clear visual hierarchy with ample whitespace",
        "consistency": "Repeated patterns across all screens",
        "feedback": "Visual feedback for all interactions",
        "efficiency": "Quick access to common actions",
        "delight": "Subtle animations and smooth transitions",
        "accessibility": "Inclusive design for all users",
        "modern": "Contemporary flat design with depth through shadows and color"
      },
  
      "usage_guidelines": {
        "color": "Use cyan as primary accent, maintain high contrast for readability",
        "typography": "Hierarchy through size and weight, not color alone",
        "spacing": "Consistent use of 8px grid system",
        "components": "Reuse components for consistency, customize minimally",
        "images": "Always use rounded corners, maintain aspect ratios",
        "icons": "Use consistent icon family, maintain 2px stroke weight",
        "forms": "Group related fields, provide clear validation feedback",
        "navigation": "Keep primary navigation easily accessible",
        "notifications": "Use badges and indicators sparingly for important updates"
