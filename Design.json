          "stat_card": {
            "background": "#E0F7FA",
            "border_radius": "16px",
            "padding": "24px",
            "icon_size": "48px",
            "icon_background": "#FFFFFF",
            "icon_border_radius": "12px",
            "number_font_size": "48px",
            "number_font_weight": "700",
            "label_font_size": "18px",
            "label_color": "#616161"
          },
          "item_card": {
            "background": "#FFFFFF",
            "border_radius": "12px",
            "padding": "16px",
            "shadow": "0 2px 6px rgba(0, 0, 0, 0.06)",
            "image_size": "120px",
            "image_border_radius": "8px"
          }
        },
  
        "badges": {
          "status": {
            "lost": {
              "background": "#00D9FF",
              "text_color": "#FFFFFF",
              "padding": "6px 12px",
              "border_radius": "6px",
              "font_size": "12px",
              "font_weight": "700",
              "text_transform": "uppercase"
            },
            "found": {
              "background": "#00D9FF",
              "text_color": "#FFFFFF",
              "padding": "6px 12px",
              "border_radius": "6px",
              "font_size": "12px",
              "font_weight": "700",
              "text_transform": "uppercase"
            }
          },
          "category": {
            "background": "#E0E0E0",
            "text_color": "#616161",
            "padding": "8px 16px",
            "border_radius": "20px",
            "font_size": "14px"
          }
        },
  
        "inputs": {
          "text_field": {
            "background": "#F8F9FA",
            "border": "none",
            "border_radius": "12px",
            "padding": "16px",
            "font_size": "16px",
            "placeholder_color": "#9E9E9E",
            "focus_border": "2px solid #00D9FF",
            "focus_background": "#FFFFFF"
          },
          "text_area": {
            "background": "#F8F9FA",
            "border": "none",
            "border_radius": "12px",
            "padding": "16px",
            "font_size": "16px",
            "min_height": "120px",
            "placeholder_color": "#9E9E9E",
            "focus_border": "2px solid #00D9FF"
          },
          "search_bar": {
            "background": "#F8F9FA",
            "border_radius": "12px",
            "padding": "12px 16px",
            "icon_color": "#00D9FF",
            "placeholder_color": "#9E9E9E"
          }
        },
  
        "navigation": {
          "bottom_navigation": {
            "height": "64px",
            "background": "#FFFFFF",
            "border_top": "1px solid #E0E0E0",
            "item_active_color": "#00D9FF",
            "item_inactive_color": "#9E9E9E",
            "icon_size": "24px",
            "label_font_size": "12px",
            "indicator": "Dot below active item"
          },
          "top_bar": {
            "height": "56px",
            "background": "#FFFFFF",
            "title_alignment": "center",
            "back_button": "left aligned",
            "action_buttons": "right aligned"
          }
        },
  
        "lists": {
          "item": {
            "padding": "16px",
            "gap": "12px",
            "divider": "1px solid #E0E0E0",
            "hover_background": "#F5F5F5"
          },
          "thumbnail": {
            "size": "48px",
            "border_radius": "8px"
          }
        },
  
        "toggles": {
          "switch": {
            "width": "52px",
            "height": "32px",
            "border_radius": "16px",
            "thumb_size": "28px",
            "active_background": "#00D9FF",
            "inactive_background": "#E0E0E0",
            "thumb_color": "#FFFFFF"
          }
        },
  
        "progress": {
          "bar": {
            "height": "8px",
            "border_radius": "4px",
            "background": "#E0E0E0",
            "fill_color": "#00D9FF"
          }
        },
  
        "tabs": {
          "horizontal": {
            "background": "transparent",
            "active_tab_background": "#00D9FF",
            "active_tab_text": "#FFFFFF",
            "inactive_tab_background": "#F0F0F0",
            "inactive_tab_text": "#616161",
            "border_radius": "12px",
            "padding": "12px 24px",
            "gap": "8px"
          }
        },
  
        "upload_area": {
          "background": "#F0FEFF",
          "border": "2px dashed #00D9FF",
          "border_radius": "12px",
          "padding": "40px",
          "icon_size": "64px",
          "icon_color": "#00D9FF",
          "hover_background": "#E0F7FA"
        }
      },
  
      "layout_patterns": {
        "page_structure": {
          "header": {
            "height": "auto",
            "padding": "16px",
            "background": "#FFFFFF",
            "greeting_section": true,
            "user_avatar": "56px circle"
          },
          "content_area": {
            "padding": "0 16px",
            "gap": "24px"
          },
          "navigation": {
            "position": "fixed bottom",
            "height": "64px"
          }
        },
        
        "grid_system": {
          "columns": "12",
          "gutter": "16px",
          "container_max_width": "100%",
          "breakpoints": {
            "mobile": "0-767px",
            "tablet": "768-1023px",
            "desktop": "1024px+"
          }
        },
  
        "common_layouts": {
          "two_column_cards": {
            "columns": 2,
            "gap": "16px",
            "equal_height": true
          },
          "list_view": {
            "direction": "vertical",
            "gap": "12px",
            "full_width": true
          },
          "grid_view": {
            "columns": 2,
            "gap": "16px",
            "responsive": "1 column on small screens"
          }
        }
      },
  
      "interactions": {
        "hover_states": {
